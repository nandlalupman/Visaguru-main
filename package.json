{
  "name": "visaguru",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "npm run build:compile && npm run build:generate",
    "build:compile": "next build --webpack --experimental-build-mode compile",
    "build:generate": "next build --webpack --experimental-build-mode generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate-legacy": "node scripts/migrate-legacy-json.mjs",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.6.0",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "mysql2": "^3.20.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "ts-api-utils": "^2.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
